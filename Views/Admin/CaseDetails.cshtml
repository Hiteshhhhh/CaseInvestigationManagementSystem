@model CaseInvestigationManagementSystem.Models.CaseModel
@{
    ViewData["Title"] = "Case Details";
}

<div class="container mt-4">
    <h3>Case Details</h3>
    <hr />

    <div class="card">
        <div class="card-body">
            <h5 class="card-title">@Model.title</h5>
            <p><strong>Description:</strong> @Model.description</p>
            <p><strong>Priority:</strong> @Model.priority</p>
            <p><strong>Status:</strong> @Model.status</p>
            <p><strong>Submitted On:</strong> @Model.created_at</p>
            <p><strong>Deadline:</strong> @Model.deadline</p>
            <p><strong>Assigned To:</strong>
                @(Model.investigator_name ?? "Not Assigned")</p>
            </div>
        </div>

        <!-- Admin Actions -->
        <div class="mt-4">
            <h5>Admin Actions</h5>

            <!-- Assign Investigator Form -->
            <div class="card mt-3">
                <div class="card-body">
                    <h5>Assign Investigator</h5>
                    <form asp-action="AssignInvestigator" method="post">
                        <input type="hidden" name="caseId" value="@Model.case_id" />
                        <div class="mb-3">
                            <select name="investigatorId" class="form-control">
                                <option value="">-- Select --</option>
                                @foreach (var inv in ViewBag.Investigators)
                                {
                                    <option value="@inv.user_id">
                                        @inv.username
                                    </option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary">
                            Assign
                        </button>
                    </form>
                </div>
            </div>

            <!-- Set Priority Form -->
            <div class="card mt-3">
                <div class="card-body">
                    <h5>Set Priority</h5>
                    <form asp-action="SetPriority" method="post">
                        <input type="hidden" name="caseId" value="@Model.case_id" />
                        <select name="priority" class="form-control">
                            <option value="Low">Low</option>
                            <option value="Medium">Medium</option>
                            <option value="High">High</option>
                            <option value="Critical">Critical</option>
                        </select>
                        <button type="submit" class="btn btn-warning mt-2">
                            Set Priority
                        </button>
                    </form>
                </div>
            </div>

            <!-- Change Status Form -->
            <div class="card mt-3">
                <div class="card-body">
                    <h5>Change Status</h5>
                    <form asp-action="ChangeStatus" method="post">
                        <input type="hidden" name="caseId" value="@Model.case_id" />
                        <select name="status" class="form-control">
                            <option value="Open">Open</option>
                            <option value="InReview">InReview</option>
                            <option value="Resolved">Resolved</option>
                            <option value="Closed">Closed</option>
                        </select>
                        <button type="submit" class="btn btn-success mt-2">
                            Update Status
                        </button>
                    </form>
                </div>
            </div>
            <a asp-action="Index" class="btn btn-secondary mt-3">
                Back
            </a>
        </div>
        <!-- Audit Trail / Timeline -->
        <div class="container mt-4">
            <h5>Investigation Timeline</h5>
            <table class="table table-striped table-sm">
                <thead>
                    <tr>
                        <th>Date/Time</th>
                        <th>Action</th>
                        <th>Old Status</th>
                        <th>New Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.AuditTrail != null)
                    {
                        @foreach (var audit in ViewBag.AuditTrail)
                        {
                            <tr>
                                <td>@audit.created_at.ToString("dd-MM-yyyy HH:mm")</td>
                                    <td>@audit.action</td>
                                    <td>@(audit.old_status ?? "-")</td>
                                    <td>@(audit.new_status ?? "-")</td>
                                </tr>
                            }
                        }
                    else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">
                                    No audit records yet!
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>