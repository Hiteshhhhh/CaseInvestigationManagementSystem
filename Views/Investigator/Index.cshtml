@model List<CaseInvestigationManagementSystem.Models.CaseModel>
@{
    ViewData["Title"] = "Assigned Cases";
}

<div class="container mt-4">
    <h3>My Assigned Cases</h3>
    <hr/>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Case Id</th>
                <th>Title</th>
                <th>Description</th>
                <th>Priority</th>
                <th>Status</th>
                <th>Deadline</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var c in Model)
            {
                <tr>
                    <td>@c.case_id</td>
                    <td>@c.title</td>
                    <td>@c.description</td>
                    <td>@c.priority</td>
                    <td>@c.status</td>
                    <td>@c.deadline</td>
                    <td>
                        <a asp-action="CaseDetails"
                           asp-route-id="@c.case_id"
                           class="btn btn-info btn-sm">
                            View
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>